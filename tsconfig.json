{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "sourceMap": false,
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "./dist/",
    "outDir": "./dist/"
  },
  "include": ["src/core/index.ts", "src/cli/index.ts"],
  "exclude": ["dist/", "node_modules/", "test-files/", "patches/", "bin/"]
}
